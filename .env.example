# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=lifeadmin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=lifeadmin
DATABASE_URL=postgresql+asyncpg://lifeadmin:changeme@localhost:5432/lifeadmin

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ─── Gmail OAuth2 ─────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com
# Enable Gmail API, create OAuth2 client (Web application)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_SECRET_HERE
OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# Stored after first OAuth flow (populated automatically)
GOOGLE_REFRESH_TOKEN=

# ─── Notifications ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password
NOTIFICATION_EMAIL=your@gmail.com

# ─── Twilio (WhatsApp / SMS) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── App Settings ─────────────────────────────────────────────────────────────
SECRET_KEY=generate-with-openssl-rand-hex-32
API_KEY=generate-with-openssl-rand-hex-32
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Agent Settings ───────────────────────────────────────────────────────────
URGENT_DAYS_THRESHOLD=2
OVERPRICED_THRESHOLD=5000
